# IFMS 로컬 개발 환경변수 샘플
# ========================================================
# 사용법:
#   cp .env.example .env
#   그 후 REQUIRED_SET_ME_ 로 시작하는 값을 실제 값으로 수정하세요
# ========================================================
# 주의: .env 파일은 Git 커밋 금지 (.gitignore 적용됨)

# -------- PostgreSQL --------
POSTGRES_DB=ifms
POSTGRES_USER=ifms
# 로컬 전용 기본값. 운영 배포 시 반드시 교체.
POSTGRES_PASSWORD=ifms1234

# -------- 애플리케이션 프로파일 --------
# local | dev | prod. prod 프로파일은 아래 SALT 기본값 거부 (백엔드 fail-fast 검증).
SPRING_PROFILES_ACTIVE=local

# -------- 감사 로그 익명화 salt --------
# 애플리케이션 기동 시 값이 REQUIRED_SET_ME_ 로 시작하면
# prod 프로파일에서는 기동 거부됩니다 (PII 복원 방지).
# 로컬/개발에서는 그대로 사용 가능.
IFMS_ACTOR_ANON_SALT=REQUIRED_SET_ME_change-before-prod

# -------- PostgreSQL advisory lock 네임스페이스 --------
# 정수(decimal)로 주입. 기본값 1229931347 = 0x49464D53 = 'IFMS' ASCII.
# 동일 PostgreSQL 인스턴스를 타 서비스와 공유할 경우 고유 값으로 변경.
IFMS_ADVISORY_LOCK_NAMESPACE=1229931347

# -------- 재처리 체인 advisory lock 네임스페이스 (ADR-005 Q4) --------
# 기본값 1229931348 = 0x49464D54 = 'IFMT' ASCII. 일반 실행 namespace와 분리.
IFMS_ADVISORY_LOCK_RETRY_NAMESPACE=1229931348
